# Polymarket L1 auth (Polygon wallet private key)
POLYMARKET_PRIVATE_KEY=0x...

# Polymarket L2 auth — derived via: python scripts/setup_credentials.py
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Kalshi — optional for data reads; required for live execution
KALSHI_API_KEY=
KALSHI_API_SECRET=

